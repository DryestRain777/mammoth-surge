# ============================================================
# Mammoth Surge backend — environment variables
# Copy this file to ".env" and fill in your real keys.
# NEVER commit the real .env file.
# ============================================================

# Server
PORT=4242
CURRENCY=usd

# The public URL of your storefront (used for Stripe success/cancel redirects + CORS).
# Local dev example: http://localhost:5510
# Production (GitHub Pages): https://dryestrain777.github.io/mammoth-surge
CLIENT_URL=https://dryestrain777.github.io/mammoth-surge

# Optional explicit redirect URLs (defaults are derived from CLIENT_URL).
# SUCCESS_URL=https://dryestrain777.github.io/mammoth-surge/success.html?session_id={CHECKOUT_SESSION_ID}
# CANCEL_URL=https://dryestrain777.github.io/mammoth-surge/cancel.html

# ---------- Stripe ----------
# Dashboard -> Developers -> API keys  (use your test key while testing)
STRIPE_SECRET_KEY=<paste-your-stripe-secret-key>
# Dashboard -> Developers -> Webhooks -> (your endpoint) -> Signing secret
# For local testing with the Stripe CLI, `stripe listen` prints this signing secret.
STRIPE_WEBHOOK_SECRET=<paste-your-webhook-signing-secret>

# ---------- ShipStation ----------
# Account -> Settings -> Account -> API Settings -> Generate API Keys
SHIPSTATION_API_KEY=your_shipstation_api_key
SHIPSTATION_API_SECRET=your_shipstation_api_secret
# Optional: route imported orders to a specific store (Settings -> Stores)
# SHIPSTATION_STORE_ID=123456
# Label shown in ShipStation's "Order Source" column for imported orders.
SHIPSTATION_ORDER_SOURCE=Mammoth Surge Web
# Advanced (rarely changed):
SHIPSTATION_BASE_URL=https://ssapi.shipstation.com
# SHIPSTATION_TIMEOUT_MS=15000
